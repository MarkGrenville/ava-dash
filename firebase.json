{
	"firestore": {
		"rules": "firestore.rules",
		"indexes": "firestore.indexes.json"
	},
	"functions": [
		{
			"source": "functions",
			"codebase": "default",
			"ignore": ["node_modules", ".git", "firebase-debug.log", "firebase-debug.*.log", "*.local"],
			"predeploy": ["pnpm --prefix \"$RESOURCE_DIR\" run build"]
		}
	],
	"hosting": {
		"public": "build",
		"ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
		"headers": [
			{
				"source": "**/*.html",
				"headers": [{ "key": "Cache-Control", "value": "no-cache" }]
			},
			{
				"source": "/",
				"headers": [{ "key": "Cache-Control", "value": "no-cache" }]
			}
		],
		"rewrites": [
			{
				"source": "/api/**",
				"function": "api"
			},
			{
				"source": "**",
				"destination": "/index.html"
			}
		]
	},
	"storage": {
		"rules": "storage.rules"
	},
	"emulators": {
		"functions": {
			"port": 7510
		},
		"firestore": {
			"port": 7511
		},
		"auth": {
			"port": 7512
		},
		"storage": {
			"port": 7513
		},
		"ui": {
			"enabled": true,
			"port": 7514
		},
		"hosting": {
			"port": 7515
		},
		"hub": {
			"port": 7516
		},
		"singleProjectMode": true
	}
}
